/* DEV109 loot tracker script - due 6/7
  This keeps the accessibility messages and focus handling.
*/

/* An array to store all loot items per instructure */
let lootArray = [];

/* Get individual elements from the page */
let nameInput = document.getElementById("loot-name");
let valueInput = document.getElementById("loot-value");
let addBtn = document.getElementById("add-btn");
let lootList = document.getElementById("loot-list");
let totalDisplay = document.getElementById("total-value");
let validationMsg = document.getElementById("validation-message");

/* When the button is clicked, add the item */
addBtn.addEventListener("click", function () {

  /* Get the text from the inputs */
  let itemName = nameInput.value.trim();
  let itemValue = valueInput.value.trim();

  /* Clear old error message */
  validationMsg.textContent = "";

  /* Check if name is empty */
  if (itemName === "") {
    validationMsg.textContent = "Item name cannot be empty.";
    nameInput.focus(); // accessibility: return focus
    return;
  }

  /* Check if value is a number */
  if (itemValue === "" || isNaN(itemValue)) {
    validationMsg.textContent = "Gold value must be a valid number.";
    valueInput.focus();
    return;
  }

  /* Convert to number and check if negative */
  let numValue = Number(itemValue);
  if (numValue < 0) {
    validationMsg.textContent = "Gold value cannot be negative.";
    valueInput.focus();
    return;
  }

  /* Make an object for the loot item */
  let lootItem = {
    name: itemName,
    value: numValue
  };

  /* This adds the loot item to the array */
  lootArray.push(lootItem);

  /* Update the list on the page */
  renderLoot();

  /* Clear the inputs for the next item */
  nameInput.value = "";
  valueInput.value = "";
  nameInput.focus(); // keep keyboard users in place
});

/* Show all loot items on the page */
function renderLoot() {

  /* Clear the list first */
  lootList.innerHTML = "";

  /* Loop through the array and make list items */
  for (let i = 0; i < lootArray.length; i++) {

    let li = document.createElement("li");

    let nameSpan = document.createElement("span");
    nameSpan.classList.add("item-name");
    nameSpan.textContent = lootArray[i].name;

    let valueSpan = document.createElement("span");
    valueSpan.classList.add("item-value");
    valueSpan.textContent = lootArray[i].value + " gp";

    li.appendChild(nameSpan);
    li.appendChild(valueSpan);

    lootList.appendChild(li);
  }

  /* Now calculate the total gold */
  let total = 0;
  for (let i = 0; i < lootArray.length; i++) {
    total += lootArray[i].value;
  }

  /* Show the total (with commas for readability) */
  totalDisplay.textContent = total.toLocaleString() + " gp";
}

